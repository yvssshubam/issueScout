# Copy this file to `env.issuescout` and fill in your own values.
# `env.issuescout` is gitignored, so your real token never gets committed.

# Required: a GitHub Personal Access Token (classic, no scopes needed for
# public data). Raises your search rate limit from ~10/min to ~30/min.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# LLM backend used ONLY to parse free-text interests and phrase explanations.
# Ranking is deterministic Python and never depends on this. Options: ollama | gemini
LLM_BACKEND=ollama

# Local Ollama (development). Ignored unless LLM_BACKEND=ollama.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Google Gemini free tier (deployment). Ignored unless LLM_BACKEND=gemini.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-1.5-flash

# Where the small "already seen" store is written (gitignored).
ISSUESCOUT_STORE=.issuescout_store.json
